{
  "datasets": [
    {
      "name": "inventario_metricas",
      "displayName": "Métricas de Inventario y Alertas",
      "config": {
        "version": "1.1",
        "source": "WITH ventas_agregadas AS (\n  SELECT \n    v.id_producto,\n    SUM(v.cantidad_salidas) AS total_salidas,\n    SUM(v.ventas_semestrales_valor) AS ventas_valor,\n    MAX(v.fecha_transaccion) AS ultima_venta\n  FROM bigdataunaula.compras_silver.fact_ventas v\n  GROUP BY v.id_producto\n) SELECT \n  s.id_producto,\n  i.nombre_producto,\n  i.proveedor,\n  i.lead_time_dias,\n  i.precio_unitario,\n  s.stock_disponible,\n  s.ranking_inventario,\n  COALESCE(v.total_salidas, 0) AS total_salidas,\n  COALESCE(v.ventas_valor, 0) AS ventas_valor,\n  v.ultima_venta,\n  CASE \n    WHEN s.stock_disponible <= 0 THEN 'STOCKOUT'\n    WHEN s.stock_disponible / NULLIF((v.total_salidas / 180.0), 0) <= i.lead_time_dias THEN 'CRÍTICO'\n    WHEN s.stock_disponible / NULLIF((v.total_salidas / 180.0), 0) > 90 THEN 'EXCESO'\n    ELSE 'NORMAL'\n  END AS estado_alerta,\n  CASE \n    WHEN s.ranking_inventario <= 20 THEN 'A - Alta Rotación'\n    WHEN s.ranking_inventario <= 50 THEN 'B - Media Rotación'\n    ELSE 'C - Baja Rotación'\n  END AS clasificacion_abc\nFROM bigdataunaula.compras_silver.fact_stock s INNER JOIN bigdataunaula.compras_silver.dim_items i ON s.id_producto = i.id_producto LEFT JOIN ventas_agregadas v ON s.id_producto = v.id_producto\n",
        "dimensions": [
          {
            "name": "id_producto",
            "expr": "id_producto",
            "comment": "Identificador único del producto"
          },
          {
            "name": "nombre_producto",
            "expr": "nombre_producto",
            "displayName": "Producto",
            "comment": "Nombre descriptivo del producto"
          },
          {
            "name": "proveedor",
            "expr": "proveedor",
            "displayName": "Proveedor",
            "comment": "Proveedor del producto"
          },
          {
            "name": "estado_alerta",
            "expr": "estado_alerta",
            "displayName": "Estado de Alerta",
            "comment": "Clasificación de urgencia de reabastecimiento (STOCKOUT, CRÍTICO, EXCESO, NORMAL)"
          },
          {
            "name": "clasificacion_abc",
            "expr": "clasificacion_abc",
            "displayName": "Clasificación ABC",
            "comment": "Segmentación de productos por importancia de inventario"
          },
          {
            "name": "lead_time_dias",
            "expr": "lead_time_dias",
            "displayName": "Lead Time (días)",
            "comment": "Días de entrega del proveedor"
          }
        ],
        "measures": [
          {
            "displayName": "Stock Disponible",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "stock_disponible",
            "expr": "SUM(stock_disponible)",
            "comment": "Unidades actuales en inventario"
          },
          {
            "displayName": "Ventas Semestrales",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "ventas_semestrales",
            "expr": "SUM(ventas_valor)",
            "comment": "Valor de ventas últimos 6 meses"
          },
          {
            "displayName": "Unidades Vendidas",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "unidades_vendidas",
            "expr": "SUM(total_salidas)",
            "comment": "Cantidad de unidades vendidas en el semestre"
          },
          {
            "displayName": "Cobertura (días)",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "cobertura_dias",
            "expr": "SUM(stock_disponible) / NULLIF(SUM(total_salidas) / 180.0, 0)",
            "comment": "Días de inventario disponibles al ritmo actual de ventas"
          },
          {
            "displayName": "Valor del Inventario",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "valor_inventario",
            "expr": "SUM(stock_disponible * precio_unitario)",
            "comment": "Valor monetario del stock actual"
          },
          {
            "displayName": "Valor en Riesgo",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "valor_en_riesgo",
            "expr": "SUM(CASE WHEN estado_alerta IN ('STOCKOUT', 'CRÍTICO') THEN ventas_valor ELSE 0 END)",
            "comment": "Valor de ventas potencialmente perdidas por falta de stock"
          },
          {
            "displayName": "Productos Críticos",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "productos_criticos",
            "expr": "COUNT(DISTINCT CASE WHEN estado_alerta IN ('STOCKOUT', 'CRÍTICO') THEN id_producto END)",
            "comment": "Número de productos en stockout o estado crítico"
          },
          {
            "displayName": "Productos con Exceso",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "productos_exceso",
            "expr": "COUNT(DISTINCT CASE WHEN estado_alerta = 'EXCESO' THEN id_producto END)",
            "comment": "Número de productos con exceso de inventario"
          },
          {
            "displayName": "Punto de Reorden",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "punto_reorden",
            "expr": "AVG((total_salidas / 180.0) * lead_time_dias * 1.5)",
            "comment": "Nivel óptimo para iniciar reabastecimiento (con margen de seguridad 50%)"
          }
        ]
      }
    }
  ],
